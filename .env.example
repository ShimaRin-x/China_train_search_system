POSTGRES_DB=railway_viz
POSTGRES_USER=railway
POSTGRES_PASSWORD=railway
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://railway:railway@postgres:5432/railway_viz
REDIS_URL=redis://redis:6379/0

BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080"]
VITE_API_BASE_URL=http://localhost:8000/api/v1

# LAN access example:
# 1. Replace 192.168.x.x with the host machine's LAN IPv4 address.
# 2. Recreate frontend/backend containers after changing these values.
# VITE_API_BASE_URL=http://192.168.x.x:8000/api/v1
# BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://192.168.x.x:5173"]
